# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (mai committare chiavi API)
.env
.env.local
.env.*.local

# Netwin cache (generata a runtime, condivisa tra worker)
data/.netwin-cache.json
data/.netwin-full.log

# Log chiamate API (retention 7 giorni)
data/.api-calls.log

# vercel
.vercel

# uploads (immagini caricate dall'admin)
/public/uploads

# typescript
*.tsbuildinfo
next-env.d.ts
