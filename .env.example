# URL pubblico del sito (per canonical, sitemap, Open Graph)
NEXT_PUBLIC_SITE_URL=https://playsignal.io

# API-Football (https://www.api-football.com/) - partite, pronostici, statistiche
API_FOOTBALL_KEY=your_api_football_key

# Backend admin - email e password per accesso a /admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me
ADMIN_SECRET=change_this_secret_in_production

# Cron live matches - protezione endpoint /api/cron/live-matches
CRON_SECRET=your_cron_secret

# Redis (opzionale) - per live matches, cache e market analytics
# REDIS_URL=redis://...

# Telegram Bot - per pubblicare post su canali (admin /ad2min3k/telegram-posts)
# Il bot deve essere admin dei canali. Crea bot con @BotFather.
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# ImgBB (opzionale) - per upload automatico immagini quando carichi un file
# Chiave gratuita su https://api.imgbb.com/ - senza chiave si usa 0x0.st
# NEXT_PUBLIC_IMGBB_API_KEY=xxx

# Market Analytics - token per GET /api/market-stats (header X-Admin-Token)
# ADMIN_ANALYTICS_TOKEN=your_analytics_admin_token

# Betboom API (JWT) - quote per Brasile. Non committare la chiave.
# BETBOOM_API_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
